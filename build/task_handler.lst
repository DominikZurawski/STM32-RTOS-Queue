 379:Core/Src/task_handler.c **** 
 380:Core/Src/task_handler.c **** 		case sRtcMenu:
 381:Core/Src/task_handler.c **** 		case sRtcTimeConfig:
 382:Core/Src/task_handler.c **** 		case sRtcDateConfig:
 383:Core/Src/task_handler.c **** 		case sRtcReport:
 384:Core/Src/task_handler.c **** 			xTaskNotify(handle_rtc_task,(uint32_t)cmd , eSetValueWithOverwrite);
 385:Core/Src/task_handler.c **** 		break;
 386:Core/Src/task_handler.c **** 
 387:Core/Src/task_handler.c **** 	}
 388:Core/Src/task_handler.c **** 
