 353:Core/Src/task_handler.c **** 		/*Implement notify wait */
 354:Core/Src/task_handler.c **** 		ret = xTaskNotifyWait(0,0,NULL,portMAX_DELAY);
 355:Core/Src/task_handler.c **** 
 356:Core/Src/task_handler.c **** 		if(ret == pdTRUE){
 357:Core/Src/task_handler.c **** 			/*process the user data(command) stored in input data queue */
