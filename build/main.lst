 402:Core/Src/main.c **** /* This function called from UART interrupt handler , hence executes in interrupt context */
 403:Core/Src/main.c **** void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart)
 404:Core/Src/main.c **** {
 405:Core/Src/main.c **** 	uint8_t dummy;
 406:Core/Src/main.c **** 
 407:Core/Src/main.c **** 	// for(uint32_t i = 0 ; i < 4000 ; i++);
 408:Core/Src/main.c **** 
 409:Core/Src/main.c **** 	if(! xQueueIsQueueFullFromISR(q_data))
 410:Core/Src/main.c **** 	{
 411:Core/Src/main.c **** 		/*Enqueue data byte */
 412:Core/Src/main.c **** 		xQueueSendFromISR(q_data , (void*)&user_data , NULL);
 413:Core/Src/main.c **** 	}else{
 414:Core/Src/main.c **** 		if(user_data == '\n')
 415:Core/Src/main.c **** 		{
 416:Core/Src/main.c **** 			/*Make sure that last data byte of the queue is '\n' */
 417:Core/Src/main.c **** 			xQueueReceiveFromISR(q_data,(void*)&dummy,NULL);
 418:Core/Src/main.c **** 			xQueueSendFromISR(q_data ,(void*)&user_data , NULL);
 419:Core/Src/main.c **** 		}
 420:Core/Src/main.c **** 	}
 421:Core/Src/main.c **** 
 422:Core/Src/main.c **** 	/*Send notification to command handling task if user_data = '\n' */
ARM GAS  /tmp/ccJ1gnI7.s 			page 12


 423:Core/Src/main.c **** 	if( user_data == '\n' ){
 424:Core/Src/main.c **** 		/*send notification to command handling task */
 425:Core/Src/main.c **** 		xTaskNotifyFromISR (handle_cmd_task,0,eNoAction,NULL);
 426:Core/Src/main.c **** 	}
 427:Core/Src/main.c **** 
 428:Core/Src/main.c **** 	/* Enable UART data byte reception again in IT mode */
 429:Core/Src/main.c **** 	 HAL_UART_Receive_IT(&huart2, (uint8_t*)&user_data, 1);
 430:Core/Src/main.c **** 
 431:Core/Src/main.c **** 
 432:Core/Src/main.c **** }
